{
  "name": "@human-horizon/code-check",
  "version": "0.3.3",
  "description": "Weft pipelines for keeping code, specs, docs, tests, and translations in sync",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "pack:dry": "pnpm pack --dry-run"
  },
  "bin": "./dist/src/cli.js",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./spec-check": {
      "import": "./dist/src/spec-check.js",
      "types": "./dist/src/spec-check.d.ts"
    },
    "./doc-check": {
      "import": "./dist/src/doc-check.js",
      "types": "./dist/src/doc-check.d.ts"
    },
    "./doc-translation-check": {
      "import": "./dist/src/doc-translation-check.js",
      "types": "./dist/src/doc-translation-check.d.ts"
    },
    "./test-check": {
      "import": "./dist/src/test-check.js",
      "types": "./dist/src/test-check.d.ts"
    },
    "./dead-code-check": {
      "import": "./dist/src/dead-code-check.js",
      "types": "./dist/src/dead-code-check.d.ts"
    },
    "./integration-e2e-check": {
      "import": "./dist/src/integration-e2e-check.js",
      "types": "./dist/src/integration-e2e-check.d.ts"
    },
    "./problem-check": {
      "import": "./dist/src/problem-check.js",
      "types": "./dist/src/problem-check.d.ts"
    },
    "./project-spec-check": {
      "import": "./dist/src/project-spec-check.js",
      "types": "./dist/src/project-spec-check.d.ts"
    }
  },
  "files": [
    "dist",
    "pipelines",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/human-horizon/code-check.git"
  },
  "homepage": "https://github.com/human-horizon/code-check",
  "bugs": {
    "url": "https://github.com/human-horizon/code-check/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "code-check",
    "specs",
    "docs",
    "tests",
    "pipeline",
    "weft",
    "ai",
    "agent"
  ],
  "dependencies": {
    "@human-horizon/weft": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
